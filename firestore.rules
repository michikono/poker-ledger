rules_version = '2';
// Deployed to production by .github/workflows/deploy-firestore.yml on push to
// main (path-filtered on this file), via scripts/deploy-firestore-config.mjs
// calling the Firebase Rules REST API (spec 0044). Client reads require auth;
// all client writes are denied — mutations go through the Admin SDK server-side.
service cloud.firestore {
  match /databases/{database}/documents {
    match /sessions/{sessionId} {
      allow read: if request.auth != null;
      allow write: if false;

      match /players/{playerId} {
        allow read: if request.auth != null;
        allow write: if false;

        match /buy_ins/{buyInId} {
          allow read: if request.auth != null;
          allow write: if false;
        }
      }

      match /payments/{paymentId} {
        allow read: if request.auth != null;
        allow write: if false;
      }

      match /change_log/{entryId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
