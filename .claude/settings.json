{
  "permissions": {
    "allow": [
      "Bash(npm run type-check)",
      "Bash(npm run lint)",
      "Bash(npm run lint:fix)",
      "Bash(npm run format)",
      "Bash(npm run format:check)",
      "Bash(npm run test)",
      "Bash(npm run test:watch)",
      "Bash(npm run test:e2e)",
      "Bash(npm run test:e2e:ui)",
      "Bash(npm run check)",
      "Bash(npm run dev)",
      "Bash(npm test)",
      "Bash(npm test *)",
      "Bash(npm view *)",
      "Bash(npm ls *)",
      "Bash(npm outdated *)",
      "Bash(npm install *)",
      "Bash(npm ci *)",
      "Bash(npx tsc --noEmit)",
      "Bash(npx tsc --noEmit *)",
      "Bash(npx vitest *)",
      "Bash(npx playwright test *)",
      "Bash(./node_modules/.bin/biome lint *)",
      "Bash(./node_modules/.bin/biome format *)",
      "Bash(./node_modules/.bin/biome --version)",
      "Bash(./node_modules/.bin/firebase --version)",
      "Bash(./node_modules/.bin/vercel --version)",
      "WebFetch(domain:firebase.google.com)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/scripts/claude-edit-guard.mjs\""
          }
        ]
      }
    ]
  }
}
