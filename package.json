{
  "name": "poker-ledger",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "preinstall": "node scripts/package-manager-guard.mjs",
    "dev": "node scripts/dev.mjs",
    "build": "next build",
    "start": "next start",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:emulator": "vitest run --config vitest.emulator.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "gen:hand-rankings": "node scripts/generate-hand-svgs.mjs",
    "check": "node scripts/lockfile-guard.mjs && node scripts/spec-status-guard.mjs && npm run format:check && npm run lint && npm run type-check && npm run test && npm run build",
    "postinstall": "lefthook install"
  },
  "packageManager": "npm@10.9.7",
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.9.0",
    "lucide-react": "^1.14.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "firebase-tools": "^15.16.0",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.6",
    "postcss": "^8.5.13",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vercel": "^53.2.0",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}
