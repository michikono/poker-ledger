# Next.js
.next/
out/

# Vercel
.vercel

# Firebase emulator data (per-worktree, not shared)
.emulator-data/
.needs-seed

# Per-worktree dev port offset + generated emulator config (spec 0008)
.devports
firebase.runtime.json

# Environment variables
.env*
!.env.local.example

# Claude Code: commit the shared, secret-free team settings and invokable skills;
# ignore all other per-user state (transcripts, agent configs, MCP credentials,
# settings.local.json). See ADR 0007 (settings) and ADR 0008 (skills).
.claude/*
!.claude/settings.json
!.claude/skills/
!.claude/skills/**

# Dependencies
node_modules/

# Test output
playwright-report/
test-results/
coverage/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Misc
.DS_Store
dist
*.log
