# Copy this to .env.local for local development.
# All values below work with the Firebase emulator — no real Firebase project needed.

# --- Client SDK (browser) ---
NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-poker-ledger
NEXT_PUBLIC_FIREBASE_API_KEY=demo-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=demo-poker-ledger.firebaseapp.com
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=demo-poker-ledger.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000

# --- Admin SDK (server) ---
# These point the Admin SDK at the local emulators instead of production Firebase.
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# In production, set these to your Firebase service account credentials (via Vercel env).
# Leave blank for local dev — the emulator needs no credentials.
FIREBASE_ADMIN_PROJECT_ID=demo-poker-ledger
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# --- Per-worktree dev ports (spec 0008) ---
# These four variables are auto-injected into child processes by `scripts/dev.mjs`
# based on the per-worktree offset stored in `.devports`. DO NOT set them here —
# the values below are documentation only, not defaults the script will honor.
#   PORT                                       # Next.js port (3000 + offset)
#   FIRESTORE_EMULATOR_HOST                    # localhost:(8080 + offset)
#   FIREBASE_AUTH_EMULATOR_HOST                # localhost:(9099 + offset)
#   NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_URL     # http://localhost:(9099 + offset)
#
# To inspect the offset for the current worktree, read `.devports` (gitignored).
# To force a new offset, delete `.devports` and re-run `npm run dev`.
